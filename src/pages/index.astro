---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
import FloatingIcon from "../components/FloatingIcon.astro";
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body
		style="background-image:url(/grain.svg),linear-gradient(to right, rgba(255, 0, 0, 0.2), rgba(0, 0, 255, 0.2)),linear-gradient(#151515,#151515)"
	>
		<Header />
		<div
			class="flex items-center justify-center w-full h-[calc(100vh_-_120px)] p-4"
		>
			
			<!-- <FloatingIcon>
				svelte
			</FloatingIcon> -->
			
			<div class="flex flex-col items-start justify-center gap-2">
				<h2>Namaste</h2>
				<p class="max-w-[55ch]">
					I am Rishab working as Middleware administrator. I am interested in Distributed Systems, Devops, Cloud Computing and WASM. 
				</p>
			</div>
		</div>
		<Footer />
	</body>
</html>
